<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>TOS M 死亡偵測測試（多視窗）</title>
<style>
  :root{
    --bg:#11151a; --panel:#1a2027; --panel2:#222a33; --line:#2e3742;
    --txt:#e6ebf1; --muted:#90a0b0; --teal:#2dd4bf; --red:#f0584f; --amber:#e0a93b;
  }
  *{box-sizing:border-box}
  body{margin:0;background:var(--bg);color:var(--txt);
    font-family:-apple-system,"PingFang TC","Microsoft JhengHei",system-ui,sans-serif;
    line-height:1.6;padding:24px}
  .wrap{max-width:960px;margin:0 auto}
  h1{font-size:22px;font-weight:600;margin:0 0 2px}
  .sub{color:var(--muted);font-size:14px;margin:0 0 20px}
  .panel{background:var(--panel);border:1px solid var(--line);border-radius:12px;padding:18px;margin-bottom:16px}
  .row{display:flex;gap:14px;align-items:center;flex-wrap:wrap}
  button{font:inherit;font-weight:600;border:0;border-radius:9px;padding:11px 18px;cursor:pointer;
    background:var(--teal);color:#04211d}
  button.ghost{background:var(--panel2);color:var(--txt);border:1px solid var(--line)}
  button.tiny{padding:5px 10px;font-size:12px}
  .pill{display:inline-flex;align-items:center;gap:7px;padding:6px 13px;border-radius:999px;
    font-weight:600;font-size:13px;background:var(--panel2);border:1px solid var(--line)}
  .dot{width:9px;height:9px;border-radius:50%;background:var(--muted)}
  .pill.alive{background:rgba(45,212,191,.13);border-color:var(--teal);color:var(--teal)}
  .pill.alive .dot{background:var(--teal)}
  .pill.death{background:rgba(240,88,79,.15);border-color:var(--red);color:var(--red)}
  .pill.death .dot{background:var(--red)}
  .settings{display:flex;gap:24px;flex-wrap:wrap;align-items:center;margin-top:14px;font-size:13px;color:var(--muted)}
  .settings label{display:block;margin-bottom:5px}
  input[type=range]{width:160px;accent-color:var(--teal);vertical-align:middle}
  input[type=number]{width:60px;font:inherit;background:var(--panel2);color:var(--txt);
    border:1px solid var(--line);border-radius:7px;padding:5px 8px}
  .val{color:var(--txt);font-weight:600}
  #cards{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}
  @media(max-width:680px){#cards{grid-template-columns:1fr}}
  .card{background:var(--panel);border:1px solid var(--line);border-radius:12px;padding:14px}
  .cardhead{display:flex;gap:10px;align-items:center;margin-bottom:10px}
  .nameInp{flex:1;font:inherit;font-weight:600;background:var(--panel2);color:var(--txt);
    border:1px solid var(--line);border-radius:7px;padding:6px 9px;min-width:0}
  canvas.prev{width:100%;background:#000;border-radius:8px;display:block;border:1px solid var(--line)}
  .meta{display:flex;align-items:baseline;gap:8px;margin-top:8px}
  .sc{font-size:26px;font-weight:700;letter-spacing:-.5px}
  .meta small{font-size:12px;color:var(--muted)}
  .empty{color:var(--muted);font-size:14px;text-align:center;padding:30px 0;grid-column:1/-1}
  #log{font-size:13px;max-height:220px;overflow:auto;margin:0;padding:0;list-style:none}
  #log li{padding:7px 10px;border-bottom:1px solid var(--line);display:flex;gap:10px}
  #log li:last-child{border-bottom:0}
  #log .t{color:var(--muted);font-variant-numeric:tabular-nums;white-space:nowrap}
  #log .w{font-weight:600;white-space:nowrap}
  #log .d{color:var(--red);font-weight:600}
  #log .a{color:var(--teal)}
  .hint{font-size:13px;color:var(--muted);margin:6px 0 0}
  .hint b{color:var(--txt);font-weight:600}
</style>
</head>
<body>
<div class="wrap">
  <h1>TOS M 死亡偵測測試（多視窗）</h1>
  <p class="sub">每個遊戲視窗各自分享、各自偵測。第一階段：只負責偵測，還沒接 LINE。</p>

  <div class="panel">
    <div class="row">
      <button id="addBtn">＋ 新增監控視窗</button>
      <button id="stopAll" class="ghost">全部停止</button>
    </div>
    <p class="hint">按「新增監控視窗」後，在跳出的視窗選 <b>一個模擬器視窗</b>（不要選整個螢幕）。要監控幾個就按幾次。視窗可在背景，但<b>不要最小化</b>。</p>
    <div class="settings">
      <div><label>判定門檻：<span class="val" id="thVal">62%</span></label>
        <input type="range" id="thresh" min="40" max="90" value="62"></div>
      <div><label>連續確認幾次才算死亡</label>
        <input type="number" id="consec" min="1" max="5" value="2"></div>
    </div>
  </div>

  <div id="cards"><div class="empty">尚未新增任何視窗</div></div>

  <div class="panel">
    <label style="font-size:13px;color:var(--muted);display:block;margin-bottom:8px">事件紀錄</label>
    <ul id="log"><li><span class="t">—</span><span>尚未開始</span></li></ul>
  </div>
</div>

<script>
const GREEN_B64="", RED_B64="";
const FRAME_W=384, BAND_FRAC=0.5, SCALE_WIDTHS=[110,130,150,170,190], STRIDE=4, INTERVAL_MS=700;

const addBtn=document.getElementById('addBtn'), stopAll=document.getElementById('stopAll');
const thresh=document.getElementById('thresh'), thVal=document.getElementById('thVal');
const consecInp=document.getElementById('consec'), cards=document.getElementById('cards'), logEl=document.getElementById('log');
thresh.oninput=()=>thVal.textContent=thresh.value+'%';

let templates=[], counter=0, monitors=[];

function loadImg(src){return new Promise(r=>{const i=new Image();i.onload=()=>r(i);i.src=src;});}
function buildTemplates(img,name){
  const out=[]; const off=document.createElement('canvas'); const octx=off.getContext('2d',{willReadFrequently:true});
  const ratio=img.naturalWidth/img.naturalHeight;
  for(const w of SCALE_WIDTHS){
    const h=Math.round(w/ratio); off.width=w; off.height=h; octx.drawImage(img,0,0,w,h);
    const d=octx.getImageData(0,0,w,h).data, n=w*h, g=new Float32Array(n); let sum=0;
    for(let p=0,q=0;p<d.length;p+=4,q++){const v=0.299*d[p]+0.587*d[p+1]+0.114*d[p+2];g[q]=v;sum+=v;}
    const mean=sum/n; let nn=0; for(let q=0;q<n;q++){g[q]-=mean;nn+=g[q]*g[q];}
    out.push({w,h,c:g,norm:Math.sqrt(nn),name});
  }
  return out;
}
async function init(){
  const g=await loadImg("data:image/png;base64,"+GREEN_B64), r=await loadImg("data:image/png;base64,"+RED_B64);
  templates=[...buildTemplates(g,'綠光'),...buildTemplates(r,'紅光')];
}
const ready=init();

function zncc(frame,fw,ox,oy,t){
  const W=t.w,H=t.h; let sum=0;
  for(let j=0;j<H;j++){const row=(oy+j)*fw+ox;for(let i=0;i<W;i++)sum+=frame[row+i];}
  const mean=sum/(W*H); let dot=0,wn=0,k=0;
  for(let j=0;j<H;j++){const row=(oy+j)*fw+ox;for(let i=0;i<W;i++){const wv=frame[row+i]-mean;dot+=wv*t.c[k];wn+=wv*wv;k++;}}
  const den=Math.sqrt(wn)*t.norm; return den>1e-6?dot/den:0;
}
function matchFrame(frame,fw,fh){
  const bandH=Math.floor(fh*BAND_FRAC); let best={score:-1,x:0,y:0,w:0,h:0};
  for(const t of templates){
    if(t.w>fw||t.h>bandH) continue;
    for(let y=0;y+t.h<=bandH;y+=STRIDE)for(let x=0;x+t.w<=fw;x+=STRIDE){
      const s=zncc(frame,fw,x,y,t); if(s>best.score) best={score:s,x,y,w:t.w,h:t.h};
    }
  }
  return best;
}

function ts(){return new Date().toTimeString().slice(0,8);}
function addLog(label,cls,txt){
  if(logEl.children.length===1&&logEl.children[0].textContent.includes('尚未'))logEl.innerHTML='';
  const li=document.createElement('li');
  li.innerHTML='<span class="t">'+ts()+'</span><span class="w">'+label+'</span><span class="'+cls+'">'+txt+'</span>';
  logEl.prepend(li);
}
function beep(){try{const a=new (window.AudioContext||window.webkitAudioContext)();
  const o=a.createOscillator(),g=a.createGain();o.frequency.value=880;o.connect(g);g.connect(a.destination);
  g.gain.setValueAtTime(.25,a.currentTime);o.start();
  g.gain.exponentialRampToValueAtTime(.001,a.currentTime+.5);o.stop(a.currentTime+.5);}catch(e){}}
function notify(label){if(window.Notification&&Notification.permission==='granted')
  new Notification('TOS M：偵測到死亡',{body:label+'　'+ts()});}

function createMonitor(stream,label){
  const card=document.createElement('div'); card.className='card';
  card.innerHTML='<div class="cardhead"><input class="nameInp"><span class="pill alive"><span class="dot"></span><span class="pt">存活中</span></span><button class="rm ghost tiny">移除</button></div>'+
    '<canvas class="prev" width="384" height="209"></canvas><div class="meta"><span class="sc">—</span><small>相似度</small></div>';
  cards.appendChild(card);
  const nameInp=card.querySelector('.nameInp'); nameInp.value=label;
  const pill=card.querySelector('.pill'), pt=card.querySelector('.pt'), sc=card.querySelector('.sc');
  const prev=card.querySelector('.prev'), pctx=prev.getContext('2d');
  const video=document.createElement('video'); video.muted=true; video.playsInline=true; video.srcObject=stream;
  const work=document.createElement('canvas'); const wctx=work.getContext('2d',{willReadFrequently:true});

  const m={stream,card,running:true,state:'alive',over:0,under:0,
    name:()=>nameInp.value||label};
  function setState(s){m.state=s;pill.className='pill '+(s==='death'?'death':'alive');pt.textContent=s==='death'?'偵測到死亡':'存活中';}
  function handleScore(score){
    const th=thresh.value/100, relax=th-0.08, need=+consecInp.value;
    if(score>=th){m.over++;m.under=0;} else if(score<relax){m.under++;m.over=0;}
    if(m.state==='alive'&&m.over>=need){setState('death');addLog(m.name(),'d','偵測到死亡（'+Math.round(score*100)+'%）');beep();notify(m.name());}
    else if(m.state==='death'&&m.under>=Math.max(2,need+1)){setState('alive');addLog(m.name(),'a','恢復存活');}
  }
  function tick(){
    if(!m.running) return;
    const vw=video.videoWidth, vh=video.videoHeight;
    if(vw&&vh){
      const fw=FRAME_W, fh=Math.round(FRAME_W*vh/vw);
      if(work.width!==fw||work.height!==fh){work.width=fw;work.height=fh;prev.width=fw;prev.height=fh;}
      wctx.drawImage(video,0,0,fw,fh);
      const d=wctx.getImageData(0,0,fw,fh).data, gray=new Float32Array(fw*fh);
      for(let p=0,q=0;p<d.length;p+=4,q++)gray[q]=0.299*d[p]+0.587*d[p+1]+0.114*d[p+2];
      const best=matchFrame(gray,fw,fh);
      sc.textContent=Math.max(0,Math.round(best.score*100))+'%';
      pctx.drawImage(video,0,0,fw,fh);
      pctx.strokeStyle='#2dd4bf';pctx.lineWidth=1;pctx.strokeRect(.5,.5,fw-1,Math.floor(fh*BAND_FRAC));
      pctx.strokeStyle='#e0a93b';pctx.lineWidth=2;pctx.strokeRect(best.x,best.y,best.w,best.h);
      handleScore(best.score);
    }
    setTimeout(()=>requestAnimationFrame(tick), INTERVAL_MS);
  }
  m.stop=()=>{m.running=false;stream.getTracks().forEach(t=>t.stop());card.remove();
    monitors=monitors.filter(x=>x!==m);if(!monitors.length)cards.innerHTML='<div class="empty">尚未新增任何視窗</div>';
    addLog(m.name(),'','已移除');};
  card.querySelector('.rm').onclick=m.stop;
  stream.getVideoTracks()[0].addEventListener('ended',m.stop);
  video.play().then(()=>setTimeout(()=>requestAnimationFrame(tick), 200+Math.random()*400));
  monitors.push(m); return m;
}

addBtn.onclick=async()=>{
  await ready;
  let stream;
  try{stream=await navigator.mediaDevices.getDisplayMedia({video:{frameRate:5},audio:false});}
  catch(e){return;}
  if(window.Notification&&Notification.permission==='default'){try{await Notification.requestPermission();}catch(e){}}
  if(monitors.length===0&&cards.querySelector('.empty'))cards.innerHTML='';
  counter++; const label='視窗 '+counter;
  createMonitor(stream,label); addLog(label,'a','開始偵測');
};
stopAll.onclick=()=>{[...monitors].forEach(m=>m.stop());};
</script>
</body>
</html>
